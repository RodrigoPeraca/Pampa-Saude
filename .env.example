# .env.example
# Copie este arquivo para .env.local e preencha com suas credenciais

# ================================
# Firebase Configuration
# ================================
# Obtenha em: https://console.firebase.google.com
# Project Settings -> General

REACT_APP_FIREBASE_API_KEY=seu_api_key_aqui
REACT_APP_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=seu-projeto
REACT_APP_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ================================
# FCM Configuration
# ================================
# Obtenha em: https://console.firebase.google.com
# Cloud Messaging -> Web Push certificates

REACT_APP_FCM_VAPID_KEY=sua_chave_vapid_aqui

# ================================
# Backend Configuration
# ================================
REACT_APP_API_URL=http://localhost:3001

# ================================
# App Configuration
# ================================
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_AUTO_REQUEST_NOTIFICATIONS=true
